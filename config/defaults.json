{
  "humanize": {
    "bezier": {
      "num_points": 20,
      "control_offset_range": 30,
      "trajectory_jitter": 1
    },
    "delays": {
      "before_click": [0.03, 0.08],
      "after_click": [0.1, 0.3],
      "before_type": [0.05, 0.15],
      "between_chars": [0.05, 0.15],
      "before_scroll": [0.05, 0.15],
      "after_scroll": [0.15, 0.3],
      "before_hotkey": [0.05, 0.15],
      "before_press_key": [0.05, 0.12]
    },
    "click": {
      "offset_range": 5
    },
    "scroll": {
      "amount_range": [-600, -300],
      "random_variance": 1
    }
  },
  "vision": {
    "template_match_threshold": 0.8,
    "bubble_threshold": 0.75,
    "copy_button_threshold": 0.75,
    "sentry_diff_threshold": 0.05,

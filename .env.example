# WechatAssistantAgent Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Configuration
LLM_API_URL=https://your-api-endpoint.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# Server Configuration
HOST=127.0.0.1
PORT=8080

# Database
DATABASE_URL=sqlite:///data/wechat.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=data/logs
